#!/usr/bin/env bash
# pipboi — one command for the whole bot. Runs everything from src/ so paths
# stay consistent no matter where you call it from.
#
#   ./pipboi                 # status card (default — "how's my bot?")
#   ./pipboi status --trades 8
#   ./pipboi run             # start the bot (sidecar + dashboard + bot)
#   ./pipboi setup           # interactive key/wallet wizard
#   ./pipboi test            # run the test suite
#   ./pipboi edge_report --by-play     # any analysis tool in src/
#   ./pipboi kill_criterion            # ...e.g. the deploy-gate verdict
#
# Type just `pipboi` from anywhere? Symlink it:  ln -s "$PWD/pipboi" /usr/local/bin/pipboi
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cmd="${1:-status}"
[ $# -gt 0 ] && shift || true

case "$cmd" in
    run)
        exec "$DIR/run.sh" "$@" ;;
    test)
        cd "$DIR"
        rc=0
        for t in tests/test_*.py; do python3 "$t" >/dev/null 2>&1 || { echo "✗ $t"; rc=1; }; done
        [ $rc -eq 0 ] && echo "✓ all tests passed" || echo "✗ some tests failed — run them directly to see why"
        exit $rc ;;
    -h|--help|help)
        sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//' ; exit 0 ;;
    *)
        # status, setup, or any analysis tool: run the matching src/<cmd>.py with src/ as CWD
        if [ ! -f "$DIR/src/$cmd.py" ]; then
            echo "pipboi: unknown command or tool '$cmd' (no src/$cmd.py). Try: ./pipboi --help" >&2
            exit 2
        fi
        cd "$DIR/src"
        exec python3 "$cmd.py" "$@" ;;
esac
