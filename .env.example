# ─────────────────────────────────────────────────────────────────────────────
#  Vault Bot — environment config.   Copy to `.env` and fill in.    cp .env.example .env
#  NEVER commit your real .env — it is gitignored. Keep your keys and keypair secret.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Helius RPC API key — the bot's connection to Solana. Free tier works to start.
# Get one at https://dashboard.helius.dev (create a project → copy the API key).
HELIUS_API_KEY=your_helius_api_key_here

# Path to the Solana keypair (wallet) the bot trades from.
# Create one with:  solana-keygen new --outfile ~/.config/solana/id.json
# ⚠ Use a FRESH wallet funded with a SMALL amount you can afford to lose entirely.
KEYPAIR_PATH=~/.config/solana/id.json

# Notional capital reference in USD (used for some sizing math). The bot actually
# sizes from your live on-chain SOL balance — fund the wallet to set real size.
TOTAL_CAPITAL_USD=100.0

# RPC node (optional): set to route through a custom node instead of Helius.
# Leave blank to use your Helius endpoint.
RPC_URL=


# ── DASHBOARD (recommended) ──────────────────────────────────────────────────
# Protect the local dashboard's admin actions. Set BOTH to long random strings.
# Generate:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SECRET=
DASHBOARD_PIN=

# Dashboard binding (optional). Default is localhost-only on port 8080.
# Set DASHBOARD_HOST=0.0.0.0 to reach it from other devices on your network.
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8080


# ── PER-BOT KEYS (optional — only if running the 3-bot fleet) ─────────────────
# Each bot can use its own Helius key to spread rate limits. If unset, all bots
# fall back to HELIUS_API_KEY above. Bots 4-6 unlock after the first "prestige".
# HELIUS_API_KEY_1=
# HELIUS_API_KEY_2=
# HELIUS_API_KEY_3=


# ── OPTIONAL DATA SOURCES (the bot runs without these) ───────────────────────
# Extra candidate feeds / risk signals. All are free-tier-capable and default OFF
# unless you enable their per-bot canary file (see SETUP.md / CLAUDE.md).
BIRDEYE_API_KEY=
LUNARCRUSH_API_KEY=
BITQUERY_API_KEY=          # Bitquery v2 GraphQL real-time feed (X-API-KEY)
SOLANATRACKER_API_KEY=     # paid candidate feed (a free DexScreener path also exists)


# ── OPTIONAL: Claude-driven advisory agents (agents/) ────────────────────────
# ANTHROPIC_API_KEY=
# AGENT_MODEL=claude-sonnet-4-6


# ── OPTIONAL: public Telegram bridge (telegram/) ─────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=@YourPublicChannel
# TELEGRAM_GROUP_ID=
# TELEGRAM_ADMIN_IDS=
