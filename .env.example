# ─────────────────────────────────────────────────────────────────────────────
#  PIPBOI — environment config.   Copy to `.env` and fill in:   cp .env.example .env
#  NEVER commit your real .env — it is gitignored. Keep your keys and keypair secret.
#  (Easiest path: don't edit this by hand — run `python3 src/setup.py`, or enter your
#   keys in the browser setup page at http://localhost:8080 on first run.)
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Helius RPC API key — the bot's connection to Solana. Free tier works to start.
# Get one at https://dashboard.helius.dev (create a project → copy the API key).
HELIUS_API_KEY=your_helius_api_key_here

# Wallet the bot trades from. You don't have to create one yourself: when you click
# "Activate" in the dashboard, PIPBOI generates a fresh wallet and shows you the
# address to fund. To use your OWN keypair instead, point this at its file.
# ⚠ Use a FRESH wallet funded with a SMALL amount you can afford to lose entirely.
KEYPAIR_PATH=~/.config/solana/pipboi.json

# Notional capital reference in USD (used for some sizing math). The bot actually
# sizes from your live on-chain SOL balance — fund the wallet to set real size.
TOTAL_CAPITAL_USD=100.0

# RPC node (optional): set to route through a custom node instead of Helius.
RPC_URL=


# ── DASHBOARD ────────────────────────────────────────────────────────────────
# Protect the local dashboard's admin actions (deploy/pause/size). The setup
# wizard generates strong values for you; the PIN is printed when you run it and
# is what you type into the dashboard to unlock admin actions.
DASHBOARD_SECRET=
DASHBOARD_PIN=

# Dashboard binding (optional). Default is localhost-only on port 8080.
# Set DASHBOARD_HOST=0.0.0.0 to reach it from other devices on your network —
# only do this behind a trusted network / proxy (see SECURITY.md).
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8080


# ── OPTIONAL: extra Helius keys to spread rate limits ────────────────────────
# If unset, everything uses HELIUS_API_KEY above.
# HELIUS_API_KEY_1=
# HELIUS_API_KEY_2=


# ── OPTIONAL DATA SOURCES (the bot runs fine without these) ──────────────────
BITQUERY_API_KEY=          # Bitquery v2 GraphQL real-time feed (X-API-KEY)
BIRDEYE_API_KEY=
LUNARCRUSH_API_KEY=
SOLANATRACKER_API_KEY=     # a free DexScreener path also exists


# ── OPTIONAL: Claude-driven advisory agents (src/agents/) ────────────────────
# Advisory only — they analyze and write notes, never touch funds.
# ANTHROPIC_API_KEY=
# AGENT_MODEL=claude-sonnet-4-6
